} from 'lucide-react'
import { QuickActions } from '@/components/QuickActions'

const FLIGHT_DECK_COLOR = '#1e40f2'

type NotificationCategory = {
  id: string
  name: string
  description: string
  enabled: boolean
  icon: any
}

type Trigger = {
  id: string
  category: string
  name: string
  description: string
}

type Action = {
  id: string
  name: string
  type: 'notify_internal' | 'notify_sales' | 'reminder' | 'suggestion'
  description: string
}

// Notification Categories
const defaultNotificationCategories: NotificationCategory[] = [
  { 
    id: 'campaign-activity', 
    name: 'Campaign Activity', 
    description: 'Campaign launches, completions, and changes',
    enabled: true,
    icon: Rocket
  },
  { 
    id: 'content-ready', 
    name: 'Content Ready', 
    description: 'Drafts completed and assets approved',
    enabled: true,
    icon: FileText
  },
  { 
    id: 'flight-deck-alerts', 
    name: 'Flight Deck Alerts', 
    description: 'Distribution and campaign deployment updates',
    enabled: true,
    icon: Activity
  },
  { 
    id: 'pulse-hub-changes', 
    name: 'Pulse Hub Changes', 
    description: 'Performance drops, intelligence updates, competitor movement',
    enabled: true,
    icon: TrendingUp
  },
  { 
    id: 'budget-alerts', 
    name: 'Budget Alerts', 
    description: 'Overspend, underspend, and reallocation requests',
    enabled: false,
    icon: DollarSign
  },
  { 
    id: 'audience-engine', 
    name: 'Audience Engine Triggers', 
    description: 'Account spikes and segment changes',
    enabled: true,
    icon: Target
  },
  { 
    id: 'abm-spike-alerts', 
    name: 'ABM Spike Alerts', 
    description: 'Target account activity spikes (Fully Stacked)',
    enabled: true,
    icon: Zap
  },
  { 
    id: 'strategy-cycle', 
    name: 'Strategy Cycle Reminders', 
    description: 'Quarterly and annual review reminders',
    enabled: true,
    icon: Calendar
  },
]

// All available triggers
const allTriggers: Trigger[] = [
  // Campaign Triggers
  { id: 'campaign-scheduled', category: 'Campaign', name: 'Campaign Scheduled', description: 'When a campaign is scheduled' },
  { id: 'campaign-launched', category: 'Campaign', name: 'Campaign Launched', description: 'When a campaign goes live' },
  { id: 'campaign-completed', category: 'Campaign', name: 'Campaign Completed', description: 'When a campaign ends' },
  { id: 'campaign-performance-drop', category: 'Campaign', name: 'Performance Drop', description: 'When campaign performance drops (Pulse Hub scoring)' },
  { id: 'campaign-asset-ready', category: 'Campaign', name: 'Asset Ready', description: 'When a campaign asset is ready in BrandCraft' },
  
  // Audience + ABM Triggers
  { id: 'account-spike', category: 'Audience/ABM', name: 'Account Spike', description: 'When an account spikes (Fully Stacked)' },
  { id: 'engagement-change', category: 'Audience/ABM', name: 'Segment Engagement Change', description: 'When engagement from a segment changes' },
  { id: 'account-threshold', category: 'Audience/ABM', name: 'Account Threshold', description: 'When account hits threshold (warm → hot)' },
  { id: 'persona-activation', category: 'Audience/ABM', name: 'Persona Segment Activates', description: 'When a persona segment activates' },
  
  // Content Triggers
  { id: 'content-draft-completed', category: 'Content', name: 'Draft Completed', description: 'When a content draft is completed' },
  { id: 'content-approved', category: 'Content', name: 'Content Approved', description: 'When content asset is approved in BrandCraft' },
  { id: 'content-published', category: 'Content', name: 'Content Published', description: 'When a piece of content goes live' },
  { id: 'content-top-performer', category: 'Content', name: 'Top Performer', description: 'When content hits performance criteria' },
  
  // Pulse Hub Triggers
  { id: 'intelligence-update', category: 'Pulse Hub', name: 'Intelligence Update', description: 'New intelligence update' },
  { id: 'activity-drop', category: 'Pulse Hub', name: 'Activity Drop', description: 'Drop in website activity' },
  { id: 'competitor-movement', category: 'Pulse Hub', name: 'Competitor Movement', description: 'Competitor activity detected' },
  { id: 'kpi-deviation', category: 'Pulse Hub', name: 'KPI Deviation', description: 'KPI deviates from target' },
  { id: 'weekly-snapshot', category: 'Pulse Hub', name: 'Weekly Snapshot Created', description: 'Weekly snapshot ready' },
  
  // Budget Triggers
  { id: 'overspend-alert', category: 'Budget', name: 'Overspend Alert', description: 'Budget overspend detected' },
  { id: 'underspend-alert', category: 'Budget', name: 'Underspend Alert', description: 'Budget underspend detected' },
  { id: 'channel-imbalance', category: 'Budget', name: 'Channel Imbalance', description: 'Budget allocation imbalance' },
  { id: 'reallocation-request', category: 'Budget', name: 'Reallocation Request', description: 'Budget reallocation request (Fully Stacked)' },
  
  // Strategy Studio Triggers
  { id: 'quarterly-review-due', category: 'Strategy Studio', name: 'Quarterly Review Due', description: 'Quarterly review reminder' },
  { id: 'annual-setup-due', category: 'Strategy Studio', name: 'Annual Setup Due', description: 'Annual planning reminder' },
